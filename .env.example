# ===============================
# OLLAMA CONFIGURATION (Phase D)
# ===============================

# Required. Must be localhost or RFC1918 LAN address.
OLLAMA_HOST=http://scooter.lan:11434

# Network request timeout (milliseconds)
# Valid range enforced at startup: 1000–300000
OLLAMA_TIMEOUT_MS=60000

# Retry attempts for transient network failures
# Valid range enforced at startup: 0–10
OLLAMA_MAX_RETRIES=3

# Health check interval (milliseconds)
# Used by OllamaHealthMonitor
OLLAMA_HEALTH_CHECK_INTERVAL_MS=30000

# ===============================
# NETWORK CONSTRAINTS
# ===============================

# Maximum simultaneous Ollama requests
MAX_CONCURRENT_REQUESTS=2

# Must be false in production builds
# Enforced by NetworkValidator
NETWORK_ENABLED_IN_PRODUCTION=false
