# Configuration for Local Canvas
# Copy this to .env and adjust for your environment

# Ollama Configuration
# Use localhost for single machine, LAN IP for network access
OLLAMA_HOST=http://localhost
OLLAMA_PORT=11434

# Resource Limits (for agent coordination)
# Percentage of available RAM agents can use (0-100)
MAX_RAM_PERCENTAGE=50
# Maximum concurrent agent tasks (0 = no limit, but recommended ≤4)
MAX_CONCURRENT_TASKS=2

# Development Settings
# Enable detailed logging for debugging
DEBUG=false
# Path to log files
LOG_PATH=./logs

# Note: These settings are read but not yet fully utilized
# Full implementation planned for Phase D