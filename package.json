{
  "name": "local-canvas",
  "version": "0.1.0",
  "description": "Local canvas utilities",
  "main": "dist/index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "smoke": "tsx scripts/smoke-test.ts",
    "agent:process": "tsx scripts/agent-process-once.ts",
    "agent:setup": "tsx scripts/setup-agent-test.ts",
    "agent:diagnose": "tsx scripts/diagnose-full.ts",
    "validate": "tsx scripts/verify-smoke.ts",
    "db:init": "tsx scripts/init-databases.ts",
    "migrate:phase-d": "tsx scripts/migrate-phase-d.ts",
    "db:health": "tsx scripts/db-health.ts",
    "health:check": "tsx scripts/check-health.ts",
    "config:validate": "tsx scripts/validate-config.ts",
    "test:evaluation": "node --env-file=.env --env-file-if-exists=.env.local node_modules/.bin/tsx scripts/test-evaluation.ts",
    "test:dotenv": "node --env-file=.env --env-file-if-exists=.env.local node_modules/.bin/tsx scripts/test-dotenv.ts",
    "test:health": "node --env-file=.env --env-file-if-exists=.env.local node_modules/.bin/tsx scripts/check-health.ts",
    "start": "tsx src/bin/cli.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dms-killa/local-canvas.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/dms-killa/local-canvas/issues"
  },
  "homepage": "https://github.com/dms-killa/local-canvas#readme",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.14.0",
    "better-sqlite3": "^12.6.2",
    "jest": "^30.2.0",
    "jest-fetch-mock": "^3.0.3",
    "ts-jest": "^29.4.6",
    "typescript": "^5.4.5"
  }
}
